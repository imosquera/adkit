{
  "name": "adkit",
  "version": "1.0.0",
  "description": "Google Ads campaign management skill — create, audit, update, report, and keyword/ad-copy generation. TypeScript port of the ads_skill Python package.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "google-ads-api": "^24.1.0",
    "tsx": "4.23.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.21.5": true,
    "protobufjs@7.6.5": true
  }
}
